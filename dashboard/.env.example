# ──────────────────────────────────────────────────────────────────────────────
# AegisAI Dashboard — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_CORS_ORIGINS=["http://localhost:3000"]

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBERNETES_API_SERVER=https://127.0.0.1:6443
KUBERNETES_NAMESPACE=aegisai-observability
KUBERNETES_TOKEN=

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock

# ── Terraform ─────────────────────────────────────────────────────────────────
TERRAFORM_DIR=../../terraform
TERRAFORM_STATE_FILE=../../terraform/terraform.tfstate

# ── Helm ──────────────────────────────────────────────────────────────────────
HELM_CHARTS_DIR=../../helm/charts

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:3200
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=Arjunrayhod
GITHUB_REPO=novapay-ai-devop

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aegisai.db

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=aegisai-dev-secret-key-change-in-production

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
