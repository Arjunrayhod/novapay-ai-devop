# AegisAI Local Lab Environment Variables
# Copy to .env and customize for your environment

# Docker Compose project name
COMPOSE_PROJECT_NAME=aegisai-lab

# Service ports (change if conflicts)
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
TEMPO_HTTP_PORT=3200
TEMPO_GRPC_PORT=4317
REGISTRY_PORT=5000

# Credentials (change for production-like environments)
POSTGRES_USER=aegisai
POSTGRES_PASSWORD=aegisai_dev_password
POSTGRES_DB=aegisai_platform
REDIS_PASSWORD=aegisai_dev_password
MINIO_ACCESS_KEY=aegisai
MINIO_SECRET_KEY=aegisai_dev_password
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
VAULT_TOKEN=root-token-12345

# Kind cluster config
KIND_CLUSTER_NAME=aegisai-lab
KIND_NODE_IMAGE=kindest/node:v1.30.0
